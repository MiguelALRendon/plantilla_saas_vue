# =============================================================================
# SaaS Vue Framework — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env files with real credentials.
# =============================================================================

# Application Identity
VITE_APP_NAME=SaaS Vue Framework
VITE_APP_VERSION=0.0.0

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=10000
VITE_API_RETRY_ATTEMPTS=3

# Runtime Environment
# Options: development | staging | production
VITE_ENVIRONMENT=development

# Logging
# Options: debug | info | warn | error
VITE_LOG_LEVEL=debug

# Authentication
VITE_AUTH_TOKEN_KEY=auth_token
VITE_AUTH_REFRESH_TOKEN_KEY=refresh_token

# Session
# Value in milliseconds (default: 30 minutes)
VITE_SESSION_TIMEOUT=1800000

# Pagination
VITE_ITEMS_PER_PAGE=20

# File Upload
# Value in bytes (default: 5 MB)
VITE_MAX_FILE_SIZE=5242880

# Language
# Options: 0 = EN (English), 1 = ES (Spanish), 2 = JP (Japanese)
VITE_SELECTED_LANGUAGE=0
